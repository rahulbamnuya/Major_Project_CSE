{
  "name": "route-optimization-server",
  "version": "1.0.0",
  "description": "Backend for Route Optimization for Capacitated Vehicles",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"npm run server\" \"npm run python\" --names \"NODE,PYTHON\" -c \"blue,yellow\"",
    "server": "nodemon server.js",
    "python": "venv\\Scripts\\python -m uvicorn main:app --reload --port 8000",
    "setup": "node setup-env.js"
  },
  "keywords": [
    "route",
    "optimization",
    "capacitated",
    "vehicles"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "geodesy": "^2.4.0",
    "geolib": "^3.3.4",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.0.3",
    "multer": "^2.0.2",
    "openrouteservice": "^0.1.2",
    "openrouteservice-js": "^0.4.1",
    "socket.io": "^4.8.1"
  },
  "optionalDependencies": {
    "@google/ortools": "^9.5.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.10"
  }
}